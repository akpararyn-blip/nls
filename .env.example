# Публичный site key от Google reCAPTCHA v3 (приватный secret хранится на хостинге в /private/config.php)
VITE_RECAPTCHA_SITE_KEY=вставь_ключ_сайта

# GTM container ID для основного домена nls.kz (для поддоменов хардкод в src/config/gtm.ts)
VITE_GTM_ID_MAIN=GTM-XXXXXXX

# ВНИМАНИЕ: токены Telegram и ERP-секреты больше НЕ хранятся во фронте.
# Они лежат только на сервере в /private/config.php (см. public/config.example.php).
